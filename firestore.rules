rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE SECURITY RULES
     * Allows public read/write access to the patients collection for easy testing.
     * In a production environment, these would be restricted by authentication.
     */
    match /patients/{patientId} {
      allow read, write: if true;
      
      // Allow access to subcollections if they exist
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }
  }
}